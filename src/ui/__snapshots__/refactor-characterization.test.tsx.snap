// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Headquarters route panel — pure move (#321) > routes tab render is stable 1`] = `
<div>
  <div
    aria-label="Headquarters"
    aria-modal="true"
    class="overlay"
    role="dialog"
  >
    <div
      class="overlay__panel overlay__panel--wide"
    >
      <h2
        class="overlay__title"
      >
        Headquarters
      </h2>
      <div
        class="overlay__tabs"
        role="tablist"
      >
        <button
          aria-selected="false"
          class="overlay__tab"
          role="tab"
          type="button"
        >
          Budowa
        </button>
        <button
          aria-selected="true"
          class="overlay__tab overlay__tab--active"
          role="tab"
          type="button"
        >
          Trasy
        </button>
      </div>
      <div
        class="overlay__body"
      >
        <div
          class="headquarters-routes"
        >
          <div
            class="route-list"
          >
            <div
              class="route-row"
            >
              <button
                class="route-row__name"
                type="button"
              >
                Char Loop
              </button>
              <div
                class="route-row__metrics"
              >
                <span>
                  Course: 
                  56
                  t/loop
                </span>
                <span>
                  Docking fees/loop: 
                  —
                </span>
                <span
                  class="route-row__result"
                >
                  Last loop:
                   
                  no loop yet
                </span>
              </div>
              <div
                class="route-row__ships"
              >
                <div
                  class="route-row__assign"
                >
                  <select
                    aria-label="Assign a ship to Char Loop"
                  >
                    <option
                      value=""
                    >
                      Assign ship…
                    </option>
                    <option
                      value="s0"
                    >
                      Aether Wing
                    </option>
                  </select>
                  <button
                    class="menu-btn"
                    disabled=""
                    type="button"
                  >
                    Assign
                  </button>
                </div>
              </div>
              <div
                class="route-row__actions"
              >
                <button
                  class="menu-btn"
                  type="button"
                >
                  Edit
                </button>
                <button
                  class="menu-btn"
                  type="button"
                >
                  Delete
                </button>
              </div>
            </div>
          </div>
          <button
            class="menu-btn"
            type="button"
          >
            New route
          </button>
        </div>
      </div>
      <button
        class="menu-btn"
        type="button"
      >
        Close
      </button>
    </div>
  </div>
</div>
`;

